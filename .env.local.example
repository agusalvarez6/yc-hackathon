# Copy to `.env.local` and fill in values. Server-side only — never commit `.env.local`.

# --- AI gateway: TokenRouter (OpenAI-compatible) ---
# Sign up at https://www.tokenrouter.com — copy the API key and base URL from your dashboard.
# Models in use: gemini-3.1-pro-preview, gemini-3.1-flash-preview, gemini-embedding-2 (1536 dim).
TOKEN_ROUTER_API_KEY=
TOKEN_ROUTER_BASE_URL=

# --- Supabase ---
# From your Supabase project: Settings > API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key — bypasses RLS. Used only by `scripts/seed-company-docs.ts`.
# Never expose to the browser, never use in client/server components.
SUPABASE_SERVICE_ROLE_KEY=
